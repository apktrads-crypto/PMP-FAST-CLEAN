generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Product {
  id            String   @id @default(cuid())
  productCode   String   @unique
  name          String
  description   String
  price         Float    // This is the current Selling Price
  originalPrice Float?   // This is the MRP
  costPrice     Float    // Secret: Your cost
  minSellPrice  Float    // Secret: Floor price
  maxDiscount   Float    // Secret: Max allowed discount
  image         String
  tag           String?
  features      String
  stock         Int      @default(0)
  rating        Float    @default(0)
  reviews       Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderItems    OrderItem[]
}

model Order {
  id            String   @id @default(cuid())
  customerName  String
  customerPhone String
  address       String
  totalAmount   Float
  paymentMethod String   // "COD", "PAYTM", "PHONEPE"
  status        String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, CANCELLED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float

  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Settings {
  id          String   @id @default("global")
  adminPin    String   @default("CHANGE_ME")
  staffPin    String   @default("1234")
  activeTheme String   @default("DEFAULT")
  qrCodeUrl   String   @default("/qr-placeholder.png")
  upiId       String?
  updatedAt   DateTime @updatedAt
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  category    String   // Rent, Salary, Bill, Misc
  date        DateTime @default(now())
  description String?
  createdAt   DateTime @default(now())
}
